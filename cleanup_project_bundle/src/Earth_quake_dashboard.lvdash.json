{
  "datasets": [
    {
      "name": "328131a6",
      "displayName": "Earthquake_details",
      "queryLines": [
        "select * from  silver.earthquake_data_final\r\n",
        "\r\n"
      ],
      "catalog": "cleanup_cat",
      "schema": "default"
    },
    {
      "name": "562ee25b",
      "displayName": "EarthQuake_type",
      "queryLines": [
        "select magnitude_bucket ,count(*) as total_magnitude\r\n",
        " from (\r\n",
        "    select \r\n",
        "    case \r\n",
        "    when mag < 2 then 'micro(<2)'\r\n",
        "    when mag between 2 and 3 then 'minor(2-3)'\r\n",
        "    when mag between 3 and 4 then 'Light(3-4)'\r\n",
        "    else 'Moderate(+4)' \r\n",
        "    end \r\n",
        "    as magnitude_bucket\r\n",
        "                                   \r\n",
        "from silver.earthquake_data_final \r\n",
        ")t \r\n",
        "group by magnitude_bucket \r\n",
        "\r\n",
        "\r\n",
        "\r\n"
      ],
      "catalog": "cleanup_cat",
      "schema": "default"
    },
    {
      "name": "a0188cae",
      "displayName": "EarthQuake_Country",
      "queryLines": [
        "select count(*) as earthquake_count,\r\n",
        "case \r\n",
        "when size(split(place,','))==1 then split(place,',')[0]\r\n",
        "else split(place,',')[1] end as country\r\n",
        "\r\n",
        "from(\r\n",
        "select \r\n",
        "time,\r\n",
        "title,\r\n",
        "mag,\r\n",
        "longitude,\r\n",
        "place,\r\n",
        "latitude\r\n",
        "from silver.earthquake_data_final)t group by country "
      ],
      "catalog": "cleanup_cat",
      "schema": "default"
    }
  ],
